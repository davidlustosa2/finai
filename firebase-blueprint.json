{
  "entities": {
    "Transaction": {
      "title": "Transaction",
      "description": "Financial transaction record",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Owner user ID" },
        "type": { "type": "string", "enum": ["income", "expense"], "description": "Transaction type" },
        "amount": { "type": "number", "description": "Transaction amount (Planned)" },
        "description": { "type": "string", "description": "Transaction description" },
        "category": { "type": "string", "description": "Category name" },
        "date": { "type": "string", "format": "date-time", "description": "Transaction date (Planned)" },
        "realizedAmount": { "type": "number", "description": "Actual realized amount" },
        "realizedDate": { "type": "string", "format": "date-time", "description": "Date when transaction was actually realized" },
        "payments": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "amount": { "type": "number" },
              "date": { "type": "string", "format": "date-time" }
            },
            "required": ["amount", "date"]
          },
          "description": "List of payments for this transaction"
        },
        "account": { "type": "string", "description": "Account name" },
        "settled": { "type": "boolean", "description": "Whether the transaction is settled" },
        "installmentGroup": { "type": "number", "description": "ID for grouping installments" },
        "recurringGroup": { "type": "number", "description": "ID for grouping recurring transactions" },
        "isRecurringEntry": { "type": "boolean", "description": "Flag for recurring entries" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "type", "amount", "description", "category", "date"]
    },
    "Account": {
      "title": "Account",
      "description": "Financial account",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Owner user ID" },
        "name": { "type": "string", "description": "Account name" },
        "balance": { "type": "number", "description": "Current balance" },
        "type": { "type": "string", "description": "Account type" }
      },
      "required": ["uid", "name", "balance"]
    },
    "Card": {
      "title": "Card/Account",
      "description": "Credit card or Bank Account",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Owner user ID" },
        "name": { "type": "string", "description": "Name of the card or account" },
        "type": { "type": "string", "enum": ["credit", "bank"], "description": "Type: credit card or bank account" },
        "limit": { "type": "number", "description": "Credit limit or overdraft limit" },
        "used": { "type": "number", "description": "Used amount or current balance" },
        "closingDate": { "type": "string", "description": "Invoice closing date (for credit cards)" },
        "dueDate": { "type": "string", "description": "Invoice due date (for credit cards)" },
        "brand": { "type": "string", "description": "Card brand (visa, mastercard, etc)" },
        "bankId": { "type": "string", "description": "Selected bank ID" },
        "bankLogo": { "type": "string", "description": "Selected bank logo URL" }
      },
      "required": ["uid", "name", "limit", "used", "type"]
    },
    "Category": {
      "title": "Category",
      "description": "Transaction category",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Owner user ID" },
        "name": { "type": "string", "description": "Category name" },
        "type": { "type": "string", "enum": ["income", "expense"], "description": "Category type" }
      },
      "required": ["uid", "name", "type"]
    }
  },
  "firestore": {
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Main transactions collection"
    },
    "/accounts/{accountId}": {
      "schema": "Account",
      "description": "User accounts"
    },
    "/cards/{cardId}": {
      "schema": "Card",
      "description": "User credit cards"
    },
    "/categories/{categoryId}": {
      "schema": "Category",
      "description": "User custom categories"
    }
  }
}
