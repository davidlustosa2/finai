rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Validations ---

    function isValidTransaction(data) {
      return data.uid == request.auth.uid &&
             data.type in ['income', 'expense'] &&
             data.amount is number &&
             data.description is string && data.description.size() <= 500 &&
             data.category is string &&
             data.date is string &&
             (data.get('settled', false) is bool) &&
             (data.get('installmentGroup', 0) is number) &&
             (data.get('recurringGroup', 0) is number) &&
             (data.get('isRecurringEntry', false) is bool);
    }

    function isValidAccount(data) {
      return data.uid == request.auth.uid &&
             data.name is string && data.name.size() <= 100 &&
             data.balance is number &&
             data.type is string;
    }

    function isValidCard(data) {
      return data.uid == request.auth.uid &&
             data.name is string && data.name.size() <= 100 &&
             data.limit is number &&
             data.used is number &&
             data.closingDate is string &&
             data.dueDate is string;
    }

    function isValidCategory(data) {
      return data.uid == request.auth.uid &&
             data.name is string && data.name.size() <= 100 &&
             data.type in ['income', 'expense'];
    }

    // --- Collection Matches ---

    match /transactions/{transactionId} {
      allow create: if isSignedIn();
      allow update, delete, get, list: if isSignedIn() && (resource == null || resource.data.uid == request.auth.uid);
    }

    match /accounts/{accountId} {
      allow create: if isSignedIn();
      allow update, delete, get, list: if isSignedIn() && (resource == null || resource.data.uid == request.auth.uid);
    }

    match /cards/{cardId} {
      allow create: if isSignedIn();
      allow update, delete, get, list: if isSignedIn() && (resource == null || resource.data.uid == request.auth.uid);
    }

    match /categories/{categoryId} {
      allow create: if isSignedIn();
      allow update, delete, get, list: if isSignedIn() && (resource == null || resource.data.uid == request.auth.uid);
    }
  }
}
