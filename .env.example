# GEMINI_API_KEY: Required for Gemini AI (Raio-X and Commands).
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="AIza..."

# Firebase Configuration (Required for the app to function)
# These values can be found in your Firebase Project Settings or the firebase-applet-config.json file.
VITE_FIREBASE_API_KEY="AIza..."
VITE_FIREBASE_AUTH_DOMAIN="your-app.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="your-project-id"
VITE_FIREBASE_STORAGE_BUCKET="your-app.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="123456789"
VITE_FIREBASE_APP_ID="1:123456789:web:abcdef"
VITE_FIREBASE_DATABASE_ID="(default)"

# Production Settings
NODE_ENV=production
PORT=3000

# WhatsApp Alerts / Evolution API Key
AUTHENTICATION_API_KEY=

# Secret token used to secure the background task trigger endpoint
CRON_SECRET_TOKEN=

